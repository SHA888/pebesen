  "query": "\n        SELECT id, stream_id, name, status as \"status: TopicStatus\", created_by, created_at, last_active\n        FROM topics\n        WHERE stream_id = $1 AND lower(name) LIKE lower($2 || '%')\n        ORDER BY last_active DESC\n        ",
