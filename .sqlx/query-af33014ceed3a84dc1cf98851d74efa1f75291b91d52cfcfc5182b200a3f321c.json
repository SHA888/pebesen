  "query": "\n            SELECT id, topic_id, author_id, content, rendered, edited_at, deleted_at, created_at\n            FROM messages\n            WHERE topic_id = $1 \n            AND deleted_at IS NULL\n            ORDER BY created_at ASC\n            LIMIT $2\n            ",
