{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.id, s.space_id, s.name, s.description, s.visibility as \"visibility: StreamVisibility\", s.created_at\n            FROM streams s\n            WHERE s.space_id = $1\n            AND (\n                s.visibility = 'public'\n                OR EXISTS (\n                    SELECT 1 FROM memberships m\n                    WHERE m.space_id = s.space_id AND m.user_id = $2\n                )\n            )\n            ",
