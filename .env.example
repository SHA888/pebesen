# ==========================
# IMPORTANT: Change these default values for production or shared environments!
# These are development-only defaults. Copy to .env and customize.
# ==========================

# Database (matches docker-compose postgres service)
DATABASE_URL=postgresql://pebesen:pebesen_dev_password@localhost:5432/pebesen

# Redis
REDIS_URL=redis://localhost:6380

# Meilisearch
MEILISEARCH_URL=http://localhost:7701
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key_at_least_16_chars

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_for_security
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
FRONTEND_URL=http://localhost:3000

# Logging
RUST_LOG=info
RUST_LOG_STYLE=full

# Docker Service Credentials
# Must match the password in DATABASE_URL above
POSTGRES_PASSWORD=pebesen_dev_password
MEILI_MASTER_KEY=pebesen_dev_master_key
